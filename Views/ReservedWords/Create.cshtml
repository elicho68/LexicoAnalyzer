@model LexicoAnalyzer.Web.ViewModels.ReservedWordFormViewModel

@{
    ViewData["Title"] = "Nueva Palabra Reservada";
}

<h2>Nueva Palabra Reservada</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Word" class="form-label"></label>
        <input asp-for="Word" class="form-control" />
        <span asp-validation-for="Word" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}