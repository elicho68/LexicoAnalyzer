@model IEnumerable<LexicoAnalyzer.Web.Models.Delimiter>

@{
    ViewData["Title"] = "Delimitadores";
}

<h2>Delimitadores</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo Delimitador</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Delimitador</th>
            <th>Activo</th>
            <th style="width:150px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Symbol</td>
                <td>@(item.IsActive ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>